CRYOVIAL_SECRET={{ cryovial_service_secret }}
CRYOVIAL_CONFIG=/etc/cryovial/services.yml
REGISTRY_TOKEN={{ cryovial_service_registry_token }}
GITHUB_APP_ID={{ cryovial_service_github_app_id }}
GITHUB_APP_INSTALLATION_ID={{ cryovial_service_github_app_installation_id }}
GITHUB_APP_PEM={{ cryovial_service_github_app_pem | default('/etc/cryovial/github-app.pem') }}
PATH={{ cryovial_service_user_home }}/.local/bin:{{ cryovial_service_path_extra }}:/usr/local/bin:/usr/bin:/bin
